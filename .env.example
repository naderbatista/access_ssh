# =============================================================================
#  CMM — Central de Gerência de Usuários
#  Copie este arquivo para .env e preencha os valores antes do deploy.
# =============================================================================

# ── Django ────────────────────────────────────────────────────────────────────
# Gere uma chave segura: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=insira-uma-chave-secreta-aqui
DEBUG=False

# Hosts permitidos (separados por vírgula, sem espaços)
# Exemplo: ALLOWED_HOSTS=empresa.com.br,10.0.0.50
ALLOWED_HOSTS=localhost,127.0.0.1

# Origens confiáveis para CSRF (necessário atrás de proxy Nginx)
# Exemplo: CSRF_TRUSTED_ORIGINS=http://empresa.com.br
CSRF_TRUSTED_ORIGINS=http://localhost

# ── Conexão padrão (pré-preenchimento no frontend — opcional) ─────────────────
SSH_HOST=
SSH_PORT=22
TELNET_PORT=23

# ── Comandos remotos ──────────────────────────────────────────────────────────
# Placeholders disponíveis: {username}, {password}, {group}

CMD_SU_LOGIN=su -
CMD_CREATE_USER=/usr/sbin/useradd -m -s /bin/bash -G {group} {username} && echo {username}:{password} | /usr/sbin/chpasswd
CMD_CHANGE_PASSWORD=echo {username}:{password} | /usr/sbin/chpasswd
CMD_CHANGE_GROUP=/usr/sbin/usermod -g {group} {username}
CMD_DELETE_USER=/usr/sbin/userdel -r {username}

