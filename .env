# SSH host remoto
SSH_HOST=192.168.18.8
SSH_PORT=22

# Django
DJANGO_SECRET_KEY=dev-insecure-key-change-in-production
DEBUG=True

# Comandos remotos
CMD_SU_LOGIN=su -
CMD_CREATE_USER=/usr/sbin/useradd -m -s /bin/bash -G {group} {username} && echo {username}:{password} | /usr/sbin/chpasswd
CMD_CHANGE_PASSWORD=echo {username}:{password} | /usr/sbin/chpasswd
CMD_CHANGE_GROUP=/usr/sbin/usermod -g {group} {username}
CMD_DELETE_USER=/usr/sbin/userdel -r {username}
